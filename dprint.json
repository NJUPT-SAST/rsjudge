{
  "newLineKind": "auto",
  "json": {
    "trailingCommas": "never"
  },
  "markdown": {},
  "toml": {
    "indentWidth": 4,
    "lineWidth": 80
  },
  "exec": {
    "cwd": "${configDir}",
    "commands": [
      {
        "command": "rustfmt +nightly",
        "exts": ["rs"]
      }
    ]
  },
  "excludes": ["/firedbg", "/target", "**/*.lock", "**/*-lock.json"],
  "plugins": [
    "https://plugins.dprint.dev/json-0.21.3.wasm",
    "https://plugins.dprint.dev/markdown-0.22.1.wasm",
    "https://plugins.dprint.dev/toml-0.7.0.wasm",
    "https://plugins.dprint.dev/exec-0.6.2.json@df98f54ffd3092b8a841aedd6d098a2651f16d0a796a40535774f1a8b4b9d463",
    "https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm",
    "https://plugins.dprint.dev/dockerfile-0.4.0.wasm"
  ]
}
